{
  "family": "backend-ts-one",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::300597388443:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend-ts-one",   // 🔥 IMPORTANT
      "image": "dummy",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ]
    }
  ]
}